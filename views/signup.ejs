<%# ── signup.ejs ── Registration Page ───────────────────────────────────── %>

<div class="min-h-[calc(100vh-130px)] flex items-center justify-center px-4 py-16 bg-[#f8f6f0]">

  <!-- Background blobs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute -top-32 -left-32 w-96 h-96 rounded-full bg-[#3ecf8e]/5 blur-3xl"></div>
    <div class="absolute -bottom-32 -right-32 w-96 h-96 rounded-full bg-[#002115]/5 blur-3xl"></div>
  </div>

  <div class="relative w-full max-w-md">

    <!-- ── Logo lockup ── -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-[#002115] shadow-lift mb-4 overflow-hidden">
        <img src="/images/scholar-snake.svg" alt="Scholar Snake"
             class="w-12 h-12 object-contain"
             onerror="this.style.display='none';this.nextElementSibling.style.display='block'" />
        <span style="display:none" class="text-2xl">🐍</span>
      </div>
      <h1 class="font-display font-bold text-3xl text-[#002115]">Join The Dial</h1>
      <p class="text-sm text-[#002115]/50 mt-1 tracking-widest uppercase font-body font-medium">
        CompSciHigh Language Platform
      </p>
    </div>

    <!-- ── Signup Card ── -->
    <div class="bg-white rounded-2xl shadow-lift border border-[#e8e4dc] overflow-hidden">

      <!-- Top band -->
      <div class="h-1.5 bg-gradient-to-r from-[#002115] via-[#3ecf8e] to-[#002115]"></div>

      <div class="px-8 py-8">
        <h2 class="font-display font-semibold text-xl text-[#002115] mb-1">Create Your Account</h2>
        <p class="text-sm text-[#002115]/50 mb-7 leading-relaxed">
          Use your <span class="font-semibold text-[#002115]/70">CompSciHigh</span> Google account for the fastest setup.
        </p>

        <!-- Google Sign-Up Button -->
        <a href="/auth/google"
           class="flex items-center justify-center gap-3 w-full py-3.5 px-6 bg-white border-2 border-[#002115]/15 hover:border-[#3ecf8e] hover:shadow-card rounded-xl text-sm font-semibold text-[#002115] transition-all duration-200 group mb-6">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" viewBox="0 0 48 48">
            <path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3C33.7 32.7 29.2 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.8 1.2 7.9 3l5.7-5.7C34 6.5 29.3 4 24 4 13 4 4 13 4 24s9 20 20 20 20-9 20-20c0-1.2-.1-2.4-.4-3.5z"/>
            <path fill="#FF3D00" d="m6.3 14.7 6.6 4.8C14.7 16.1 19 13 24 13c3.1 0 5.8 1.2 7.9 3l5.7-5.7C34 6.5 29.3 4 24 4 16.3 4 9.7 8.3 6.3 14.7z"/>
            <path fill="#4CAF50" d="M24 44c5.2 0 9.9-2 13.4-5.2l-6.2-5.2C29.2 35.3 26.7 36 24 36c-5.2 0-9.6-3.3-11.3-8H6.3C9.7 35.7 16.3 44 24 44z"/>
            <path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-.8 2.2-2.3 4.1-4.1 5.4l6.2 5.2C43.2 35.3 46 30.2 46 24c0-1.2-.1-2.4-.4-3.5z"/>
          </svg>
          <span>Sign up with Google</span>
        </a>

        <!-- Divider -->
        <div class="relative mb-6">
          <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-[#e8e4dc]"></div></div>
          <div class="relative flex justify-center"><span class="bg-white px-3 text-xs text-[#002115]/30">or register manually</span></div>
        </div>

        <!-- ── Registration Form ── -->
        <form method="POST" action="/auth/signup" class="space-y-4" id="signup-form">

          <!-- Name row -->
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-xs font-medium text-[#002115]/60 mb-1.5" for="firstName">First Name</label>
              <input id="firstName" name="firstName" type="text" placeholder="Alex" required
                     class="w-full px-4 py-3 rounded-xl border border-[#e8e4dc] bg-[#fdfcf9] text-sm text-[#002115] placeholder-[#002115]/30 focus:outline-none focus:ring-2 focus:ring-[#3ecf8e]/40 focus:border-[#3ecf8e] transition-all duration-200" />
            </div>
            <div>
              <label class="block text-xs font-medium text-[#002115]/60 mb-1.5" for="lastName">Last Name</label>
              <input id="lastName" name="lastName" type="text" placeholder="Rivera" required
                     class="w-full px-4 py-3 rounded-xl border border-[#e8e4dc] bg-[#fdfcf9] text-sm text-[#002115] placeholder-[#002115]/30 focus:outline-none focus:ring-2 focus:ring-[#3ecf8e]/40 focus:border-[#3ecf8e] transition-all duration-200" />
            </div>
          </div>

          <!-- Email -->
          <div>
            <label class="block text-xs font-medium text-[#002115]/60 mb-1.5" for="email">
              School Email <span class="text-red-400">*</span>
            </label>
            <div class="relative">
              <i data-lucide="mail" class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-[#002115]/30"></i>
              <input id="email" name="email" type="email" placeholder="you@compscihigh.org" required
                     class="w-full pl-10 pr-4 py-3 rounded-xl border border-[#e8e4dc] bg-[#fdfcf9] text-sm text-[#002115] placeholder-[#002115]/30 focus:outline-none focus:ring-2 focus:ring-[#3ecf8e]/40 focus:border-[#3ecf8e] transition-all duration-200" />
            </div>
            <p id="email-hint" class="text-[11px] text-[#002115]/30 mt-1.5 ml-1">Must end in @compscihigh.org</p>
          </div>

          <!-- Role selector -->
          <div>
            <label class="block text-xs font-medium text-[#002115]/60 mb-2">I am a… <span class="text-red-400">*</span></label>
            <div class="grid grid-cols-2 gap-3">
              <label class="role-option relative flex flex-col items-center gap-2 p-4 rounded-xl border-2 border-[#e8e4dc] cursor-pointer transition-all duration-200 hover:border-[#3ecf8e]/50 has-[:checked]:border-[#3ecf8e] has-[:checked]:bg-[#3ecf8e]/5">
                <input type="radio" name="role" value="student" class="sr-only" checked />
                <i data-lucide="graduation-cap" class="w-6 h-6 text-[#002115]/50"></i>
                <span class="text-sm font-semibold text-[#002115]">Student</span>
              </label>
              <label class="role-option relative flex flex-col items-center gap-2 p-4 rounded-xl border-2 border-[#e8e4dc] cursor-pointer transition-all duration-200 hover:border-[#3ecf8e]/50 has-[:checked]:border-[#3ecf8e] has-[:checked]:bg-[#3ecf8e]/5">
                <input type="radio" name="role" value="teacher" class="sr-only" />
                <i data-lucide="book-open" class="w-6 h-6 text-[#002115]/50"></i>
                <span class="text-sm font-semibold text-[#002115]">Teacher</span>
              </label>
            </div>
          </div>

          <!-- Reading Level (students only) -->
          <div id="level-section">
            <label class="block text-xs font-medium text-[#002115]/60 mb-1.5">Starting Reading Level</label>
            <select name="level"
                    class="w-full px-4 py-3 rounded-xl border border-[#e8e4dc] bg-[#fdfcf9] text-sm text-[#002115] focus:outline-none focus:ring-2 focus:ring-[#3ecf8e]/40 focus:border-[#3ecf8e] transition-all">
              <option value="A1">Novice (A1) — I'm just starting out</option>
              <option value="A2">Elementary (A2) — I know some basics</option>
              <option value="B1" selected>Intermediate (B1) — I'm comfortable reading</option>
              <option value="B2">Advanced (B2) — I want a challenge</option>
            </select>
          </div>

          <!-- Password -->
          <div>
            <label class="block text-xs font-medium text-[#002115]/60 mb-1.5" for="password">
              Password <span class="text-red-400">*</span>
            </label>
            <div class="relative">
              <i data-lucide="lock" class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-[#002115]/30"></i>
              <input id="password" name="password" type="password" placeholder="Min. 8 characters" required minlength="8"
                     class="w-full pl-10 pr-11 py-3 rounded-xl border border-[#e8e4dc] bg-[#fdfcf9] text-sm text-[#002115] placeholder-[#002115]/30 focus:outline-none focus:ring-2 focus:ring-[#3ecf8e]/40 focus:border-[#3ecf8e] transition-all duration-200" />
              <button type="button" id="toggle-pw"
                      class="absolute right-3.5 top-1/2 -translate-y-1/2 text-[#002115]/30 hover:text-[#002115] transition-colors">
                <i data-lucide="eye" class="w-4 h-4"></i>
              </button>
            </div>
            <!-- Password strength bar -->
            <div class="mt-2 h-1 w-full bg-[#e8e4dc] rounded-full overflow-hidden">
              <div id="strength-bar" class="h-full w-0 rounded-full transition-all duration-300"></div>
            </div>
            <p id="strength-label" class="text-[11px] text-[#002115]/30 mt-1 ml-1">Enter a password</p>
          </div>

          <!-- Confirm Password -->
          <div>
            <label class="block text-xs font-medium text-[#002115]/60 mb-1.5" for="confirmPassword">
              Confirm Password <span class="text-red-400">*</span>
            </label>
            <div class="relative">
              <i data-lucide="lock-keyhole" class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-[#002115]/30"></i>
              <input id="confirmPassword" name="confirmPassword" type="password" placeholder="Repeat your password" required
                     class="w-full pl-10 pr-4 py-3 rounded-xl border border-[#e8e4dc] bg-[#fdfcf9] text-sm text-[#002115] placeholder-[#002115]/30 focus:outline-none focus:ring-2 focus:ring-[#3ecf8e]/40 focus:border-[#3ecf8e] transition-all duration-200" />
            </div>
            <p id="match-hint" class="text-[11px] mt-1.5 ml-1 hidden"></p>
          </div>

          <!-- Error message from server -->
          <% if (typeof error !== 'undefined' && error) { %>
          <div class="flex items-start gap-2.5 bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 rounded-xl">
            <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0 mt-0.5"></i>
            <span><%= error %></span>
          </div>
          <% } %>

          <!-- Terms checkbox -->
          <label class="flex items-start gap-3 cursor-pointer group pt-1">
            <input type="checkbox" name="terms" required
                   class="mt-0.5 w-4 h-4 rounded border-[#e8e4dc] text-[#3ecf8e] focus:ring-[#3ecf8e] flex-shrink-0" />
            <span class="text-xs text-[#002115]/50 leading-relaxed group-hover:text-[#002115]/70 transition-colors">
              I agree to the
              <a href="/terms" class="text-[#3ecf8e] hover:underline">Terms of Use</a> and
              <a href="/privacy" class="text-[#3ecf8e] hover:underline">Privacy Policy</a>.
              I confirm I am a CompSciHigh student or faculty member.
            </span>
          </label>

          <!-- Submit -->
          <button type="submit" id="submit-btn"
                  class="w-full flex items-center justify-center gap-2 bg-[#002115] hover:bg-[#001a10] text-white font-semibold text-sm py-3.5 rounded-xl shadow-card hover:shadow-lift transition-all duration-200 active:scale-95 mt-2">
            <i data-lucide="user-plus" class="w-4 h-4 text-[#3ecf8e]"></i>
            Create Account
          </button>
        </form>
      </div>

      <!-- Card footer -->
      <div class="px-8 py-5 bg-[#f8f6f0] border-t border-[#e8e4dc] flex items-center justify-between">
        <span class="text-xs text-[#002115]/40">Already have an account?</span>
        <a href="/login" class="text-xs font-semibold text-[#3ecf8e] hover:underline flex items-center gap-1">
          Sign in instead <i data-lucide="arrow-right" class="w-3 h-3"></i>
        </a>
      </div>
    </div>

  </div>
</div>

<script>
  lucide.createIcons();

  // ── Show/hide password ───────────────────────────────────────────
  const pwField  = document.getElementById('password');
  const togglePw = document.getElementById('toggle-pw');
  togglePw.addEventListener('click', () => {
    const show = pwField.type === 'password';
    pwField.type = show ? 'text' : 'password';
    togglePw.innerHTML = show
      ? '<i data-lucide="eye-off" class="w-4 h-4"></i>'
      : '<i data-lucide="eye" class="w-4 h-4"></i>';
    lucide.createIcons();
  });

  // ── Password strength ────────────────────────────────────────────
  const bar    = document.getElementById('strength-bar');
  const label  = document.getElementById('strength-label');
  const levels = [
    { pct: '0%',   color: '',            text: 'Enter a password',  cls: 'text-[#002115]/30' },
    { pct: '25%',  color: 'bg-red-400',  text: 'Too weak',          cls: 'text-red-500'      },
    { pct: '50%',  color: 'bg-amber-400',text: 'Could be stronger', cls: 'text-amber-600'    },
    { pct: '75%',  color: 'bg-blue-400', text: 'Good',              cls: 'text-blue-600'     },
    { pct: '100%', color: 'bg-[#3ecf8e]',text: 'Strong password ✓', cls: 'text-[#22a06b]'   },
  ];

  pwField.addEventListener('input', () => {
    const v = pwField.value;
    let score = 0;
    if (v.length >= 8)              score++;
    if (/[A-Z]/.test(v))            score++;
    if (/[0-9]/.test(v))            score++;
    if (/[^A-Za-z0-9]/.test(v))     score++;
    const l = v.length === 0 ? levels[0] : levels[score] || levels[4];
    bar.style.width     = l.pct;
    bar.className       = `h-full rounded-full transition-all duration-300 ${l.color}`;
    label.textContent   = l.text;
    label.className     = `text-[11px] mt-1 ml-1 ${l.cls}`;
  });

  // ── Password match hint ──────────────────────────────────────────
  const confirmPw  = document.getElementById('confirmPassword');
  const matchHint  = document.getElementById('match-hint');
  confirmPw.addEventListener('input', () => {
    if (!confirmPw.value) { matchHint.classList.add('hidden'); return; }
    matchHint.classList.remove('hidden');
    if (confirmPw.value === pwField.value) {
      matchHint.textContent  = '✓ Passwords match';
      matchHint.className    = 'text-[11px] mt-1.5 ml-1 text-[#22a06b]';
      confirmPw.classList.remove('border-red-300');
      confirmPw.classList.add('border-[#3ecf8e]');
    } else {
      matchHint.textContent  = '✗ Passwords don\'t match';
      matchHint.className    = 'text-[11px] mt-1.5 ml-1 text-red-500';
      confirmPw.classList.remove('border-[#3ecf8e]');
      confirmPw.classList.add('border-red-300');
    }
  });

  // ── Email domain validation ──────────────────────────────────────
  const emailField = document.getElementById('email');
  const emailHint  = document.getElementById('email-hint');
  emailField.addEventListener('input', () => {
    if (!emailField.value) { emailHint.textContent = 'Must end in @compscihigh.org'; emailHint.className = 'text-[11px] text-[#002115]/30 mt-1.5 ml-1'; return; }
    if (emailField.value.endsWith('@compscihigh.org')) {
      emailHint.textContent = '✓ Valid school email';
      emailHint.className   = 'text-[11px] text-[#22a06b] mt-1.5 ml-1';
    } else {
      emailHint.textContent = '✗ Must end in @compscihigh.org';
      emailHint.className   = 'text-[11px] text-red-500 mt-1.5 ml-1';
    }
  });

  // ── Hide level selector for teachers ────────────────────────────
  const levelSection = document.getElementById('level-section');
  document.querySelectorAll('input[name="role"]').forEach(radio => {
    radio.addEventListener('change', () => {
      levelSection.style.display = radio.value === 'teacher' ? 'none' : '';
    });
  });

  // ── Client-side submit guard ─────────────────────────────────────
  document.getElementById('signup-form').addEventListener('submit', e => {
    if (pwField.value !== confirmPw.value) {
      e.preventDefault();
      confirmPw.focus();
    }
    if (!emailField.value.endsWith('@compscihigh.org')) {
      e.preventDefault();
      emailField.focus();
    }
  });
</script>