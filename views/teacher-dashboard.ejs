<%# ── teacher-dashboard.ejs ── Teacher View ──────────────────────────── %>

<%
const teacher = typeof user !== 'undefined' ? user : { name: 'Dr. Okafor', subject: 'Computer Science' };

const classStats = typeof stats !== 'undefined' ? stats : {
  totalStudents: 28, activeToday: 19, avgLevel: 'B1', articlesThisWeek: 47
};

const struggleWords = typeof words !== 'undefined' ? words : [
  { word: 'Abstraction',  clicks: 34, level: 'B2' },
  { word: 'Polymorphism', clicks: 28, level: 'B2' },
  { word: 'Recursion',    clicks: 24, level: 'B1' },
  { word: 'Encapsulation',clicks: 21, level: 'B2' },
  { word: 'Heuristic',    clicks: 18, level: 'B2' },
  { word: 'Iteration',    clicks: 15, level: 'B1' },
  { word: 'Syntax',       clicks: 12, level: 'A2' },
  { word: 'Compile',      clicks:  9, level: 'A2' },
];

const maxClicks = struggleWords[0] ? struggleWords[0].clicks : 1;

const activityData = typeof activity !== 'undefined' ? activity : [
  { day: 'Mon', count: 8  },
  { day: 'Tue', count: 15 },
  { day: 'Wed', count: 12 },
  { day: 'Thu', count: 22 },
  { day: 'Fri', count: 19 },
  { day: 'Sat', count: 5  },
  { day: 'Sun', count: 3  },
];

const levelBadge = { A1: 'badge-novice', A2: 'badge-elementary', B1: 'badge-intermediate', B2: 'badge-advanced' };
%>

<div class="max-w-7xl mx-auto px-6 py-10">

  <!-- ── Page Header ── -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
    <div>
      <p class="text-xs text-[#002115]/40 uppercase tracking-widest font-medium mb-0.5">Teacher Portal</p>
      <h1 class="font-display font-bold text-3xl text-[#002115]">Welcome, <%= teacher.name %></h1>
      <p class="text-sm text-[#002115]/50 mt-1"><%= teacher.subject %> &middot; <%= classStats.totalStudents %> students enrolled</p>
    </div>
    <div class="flex items-center gap-3 flex-wrap">
      <a href="/teacher/students"
         class="inline-flex items-center gap-2 text-sm font-medium border border-[#002115]/15 hover:border-[#3ecf8e] text-[#002115]/70 hover:text-[#002115] px-4 py-2.5 rounded-xl transition-all duration-200">
        <i data-lucide="users" class="w-4 h-4"></i> All Students
      </a>
      <a href="/teacher/export"
         class="inline-flex items-center gap-2 text-sm font-medium bg-[#002115] hover:bg-[#001a10] text-white px-4 py-2.5 rounded-xl shadow-card hover:shadow-lift transition-all duration-200">
        <i data-lucide="download" class="w-4 h-4 text-[#3ecf8e]"></i> Export Report
      </a>
    </div>
  </div>

  <!-- ── Stat Cards ── -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
    <%
    const kpis = [
      { icon: 'users',         label: 'Total Students',    value: String(classStats.totalStudents), delta: null,     deltaDir: null  },
      { icon: 'activity',      label: 'Active Today',      value: String(classStats.activeToday),  delta: '68%',    deltaDir: 'up'  },
      { icon: 'trending-up',   label: 'Avg. Class Level',  value: classStats.avgLevel,             delta: null,     deltaDir: null  },
      { icon: 'book-open',     label: 'Articles This Week',value: String(classStats.articlesThisWeek), delta: '+12%', deltaDir: 'up' },
    ];
    %>
    <% kpis.forEach(k => { %>
    <div class="bg-white rounded-2xl border border-[#e8e4dc] p-5 shadow-card">
      <div class="flex items-center justify-between mb-3">
        <div class="w-9 h-9 rounded-xl bg-[#002115] flex items-center justify-center">
          <i data-lucide="<%= k.icon %>" class="w-4 h-4 text-[#3ecf8e]"></i>
        </div>
        <% if (k.delta) { %>
        <span class="text-xs font-semibold text-[#3ecf8e] bg-[#3ecf8e]/10 px-2 py-0.5 rounded-full">
          ↑ <%= k.delta %>
        </span>
        <% } %>
      </div>
      <p class="text-2xl font-display font-bold text-[#002115]"><%= k.value %></p>
      <p class="text-xs text-[#002115]/50 mt-0.5"><%= k.label %></p>
    </div>
    <% }) %>
  </div>

  <!-- ── Main Grid ── -->
  <div class="grid grid-cols-1 xl:grid-cols-3 gap-8">

    <!-- ════ Left column (2/3) ════ -->
    <div class="xl:col-span-2 space-y-8">

      <!-- ── Class Activity Chart ── -->
      <div class="bg-white rounded-2xl border border-[#e8e4dc] shadow-card overflow-hidden">
        <div class="px-6 py-5 border-b border-[#e8e4dc] flex items-center justify-between">
          <div>
            <h2 class="font-display font-semibold text-lg text-[#002115] flex items-center gap-2">
              <i data-lucide="bar-chart-2" class="w-5 h-5 text-[#3ecf8e]"></i>
              Class Activity
            </h2>
            <p class="text-xs text-[#002115]/40 mt-0.5">Articles simplified · last 7 days</p>
          </div>
          <select class="text-xs border border-[#e8e4dc] bg-[#fdfcf9] text-[#002115]/60 px-3 py-1.5 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#3ecf8e]/40">
            <option>Last 7 days</option>
            <option>Last 30 days</option>
            <option>This semester</option>
          </select>
        </div>

        <!-- Chart.js placeholder ─ swap #chart-container with a <canvas> once Chart.js is wired up -->
        <div class="p-6">
          <div id="chart-container" class="relative h-56 w-full rounded-xl bg-[#f8f6f0] border border-[#e8e4dc] flex items-end gap-2 px-4 pb-8 pt-4 overflow-hidden">
            <!-- Inline bar chart preview (no JS dependency) -->
            <div class="absolute bottom-8 left-4 right-4 top-4 flex items-end gap-2">
              <% activityData.forEach(d => {
                   const pct = Math.round((d.count / 22) * 100);
              %>
              <div class="flex-1 flex flex-col items-center gap-1 group">
                <span class="text-[10px] font-mono text-[#002115]/40 opacity-0 group-hover:opacity-100 transition-opacity -mt-4"><%= d.count %></span>
                <div class="w-full rounded-t-md bg-gradient-to-t from-[#002115] to-[#3ecf8e]/70 transition-all duration-300 hover:from-[#3ecf8e] hover:to-[#7eeab8]"
                     style="height: <%= pct %>%;"></div>
              </div>
              <% }) %>
            </div>
            <!-- Day labels -->
            <div class="absolute bottom-2 left-4 right-4 flex gap-2">
              <% activityData.forEach(d => { %>
              <div class="flex-1 text-center text-[10px] font-medium text-[#002115]/40"><%= d.day %></div>
              <% }) %>
            </div>
            <!-- Replace me note -->
            <div class="absolute top-2 right-3 text-[9px] font-mono text-[#002115]/20 bg-white px-2 py-0.5 rounded border border-[#e8e4dc]">
              Chart.js · id="chart-container"
            </div>
          </div>
          <!-- Wire up Chart.js here: const ctx = document.getElementById('chart-container').getContext('2d'); -->
        </div>
      </div>

      <!-- ── Assign Reading Form ── -->
      <div class="bg-white rounded-2xl border border-[#e8e4dc] shadow-card overflow-hidden">
        <div class="px-6 py-5 border-b border-[#e8e4dc]">
          <h2 class="font-display font-semibold text-lg text-[#002115] flex items-center gap-2">
            <i data-lucide="send" class="w-5 h-5 text-[#3ecf8e]"></i>
            Assign Reading
          </h2>
          <p class="text-xs text-[#002115]/40 mt-0.5">Blast a URL to every student in your class.</p>
        </div>

        <form method="POST" action="/teacher/assign" class="p-6 space-y-5">
          <div>
            <label class="block text-xs font-medium text-[#002115]/60 mb-1.5" for="assign-url">
              Article URL <span class="text-red-400">*</span>
            </label>
            <input id="assign-url" name="url" type="url" required
                   placeholder="https://example.com/article"
                   class="w-full px-4 py-3 rounded-xl border border-[#e8e4dc] bg-[#fdfcf9] text-sm text-[#002115] placeholder-[#002115]/30 focus:outline-none focus:ring-2 focus:ring-[#3ecf8e]/40 focus:border-[#3ecf8e] transition-all duration-200" />
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-medium text-[#002115]/60 mb-1.5" for="assign-level">
                Simplification Level <span class="text-red-400">*</span>
              </label>
              <select id="assign-level" name="level" required
                      class="w-full px-4 py-3 rounded-xl border border-[#e8e4dc] bg-[#fdfcf9] text-sm text-[#002115] focus:outline-none focus:ring-2 focus:ring-[#3ecf8e]/40 focus:border-[#3ecf8e] transition-all">
                <option value="A1">Novice (A1)</option>
                <option value="A2">Elementary (A2)</option>
                <option value="B1" selected>Intermediate (B1)</option>
                <option value="B2">Advanced (B2)</option>
              </select>
            </div>
            <div>
              <label class="block text-xs font-medium text-[#002115]/60 mb-1.5" for="assign-due">
                Due Date <span class="text-[#002115]/30 font-normal">(optional)</span>
              </label>
              <input id="assign-due" name="dueDate" type="date"
                     class="w-full px-4 py-3 rounded-xl border border-[#e8e4dc] bg-[#fdfcf9] text-sm text-[#002115] focus:outline-none focus:ring-2 focus:ring-[#3ecf8e]/40 focus:border-[#3ecf8e] transition-all" />
            </div>
          </div>

          <div>
            <label class="block text-xs font-medium text-[#002115]/60 mb-1.5" for="assign-note">
              Note to Students <span class="text-[#002115]/30 font-normal">(optional)</span>
            </label>
            <textarea id="assign-note" name="note" rows="2"
                      placeholder="E.g. Focus on the section about sorting algorithms."
                      class="w-full resize-none px-4 py-3 rounded-xl border border-[#e8e4dc] bg-[#fdfcf9] text-sm text-[#002115] placeholder-[#002115]/30 focus:outline-none focus:ring-2 focus:ring-[#3ecf8e]/40 focus:border-[#3ecf8e] transition-all"></textarea>
          </div>

          <div class="flex items-center justify-between pt-1">
            <label class="flex items-center gap-2 text-xs text-[#002115]/50 cursor-pointer">
              <input type="checkbox" name="notify" value="1" checked
                     class="w-4 h-4 rounded border-[#e8e4dc] text-[#3ecf8e] focus:ring-[#3ecf8e]" />
              Notify students via email
            </label>
            <button type="submit"
                    class="flex items-center gap-2 bg-[#002115] hover:bg-[#001a10] text-white text-sm font-semibold px-6 py-3 rounded-xl shadow-card hover:shadow-lift transition-all active:scale-95">
              <i data-lucide="send" class="w-4 h-4 text-[#3ecf8e]"></i>
              Assign to Class
            </button>
          </div>
        </form>
      </div>

      <!-- ── Enroll Students ── -->
      <div class="bg-white rounded-2xl border border-[#e8e4dc] shadow-card overflow-hidden">
        <div class="px-6 py-5 border-b border-[#e8e4dc] flex items-center justify-between">
          <div>
            <h2 class="font-display font-semibold text-lg text-[#002115] flex items-center gap-2">
              <i data-lucide="user-plus" class="w-5 h-5 text-[#3ecf8e]"></i>
              Enroll Students
            </h2>
            <p class="text-xs text-[#002115]/40 mt-0.5">Add a student by email or share your class code.</p>
          </div>
        </div>

        <div class="p-6 space-y-6">

          <!-- Class code display -->
          <div class="bg-[#f8f6f0] border border-[#e8e4dc] rounded-xl p-4">
            <p class="text-xs font-medium text-[#002115]/50 mb-2 flex items-center gap-1.5">
              <i data-lucide="key-round" class="w-3.5 h-3.5 text-[#3ecf8e]"></i>
              Your Class Code — share this with students
            </p>
            <div class="flex items-center justify-between gap-3">
              <span id="class-code" class="font-mono font-bold text-2xl text-[#002115] tracking-widest">CS-4829</span>
              <button onclick="copyCode()"
                      class="flex items-center gap-1.5 text-xs font-medium bg-white border border-[#e8e4dc] hover:border-[#3ecf8e] text-[#002115]/60 hover:text-[#002115] px-3 py-2 rounded-lg transition-all">
                <i data-lucide="copy" class="w-3.5 h-3.5"></i>
                <span id="copy-label">Copy</span>
              </button>
            </div>
          </div>

          <!-- Add by email -->
          <form method="POST" action="/teacher/enroll" class="space-y-3">
            <label class="block text-xs font-medium text-[#002115]/60 mb-1.5">
              Add Student by Email
            </label>
            <div class="relative">
              <i data-lucide="mail" class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-[#002115]/30"></i>
              <input type="email" name="studentEmail" placeholder="student@compscihigh.org" required
                     class="w-full pl-10 pr-4 py-3 rounded-xl border border-[#e8e4dc] bg-[#fdfcf9] text-sm text-[#002115] placeholder-[#002115]/30 focus:outline-none focus:ring-2 focus:ring-[#3ecf8e]/40 focus:border-[#3ecf8e] transition-all" />
            </div>
            <button type="submit"
                    class="w-full flex items-center justify-center gap-2 bg-[#002115] hover:bg-[#001a10] text-white text-sm font-semibold py-3 rounded-xl transition-all active:scale-95">
              <i data-lucide="user-plus" class="w-4 h-4 text-[#3ecf8e]"></i>
              Add to Class
            </button>
          </form>

          <!-- Bulk enroll -->
          <div>
            <p class="text-xs font-medium text-[#002115]/50 mb-2 flex items-center gap-1.5">
              <i data-lucide="users" class="w-3.5 h-3.5 text-[#3ecf8e]"></i>
              Bulk Enroll via CSV
            </p>
            <form method="POST" action="/teacher/enroll/bulk" enctype="multipart/form-data" class="flex items-center gap-2">
              <label class="flex-1 flex items-center gap-2 px-4 py-2.5 rounded-xl border border-dashed border-[#e8e4dc] hover:border-[#3ecf8e] bg-[#fdfcf9] cursor-pointer transition-all text-xs text-[#002115]/40 hover:text-[#002115]/60">
                <i data-lucide="upload" class="w-3.5 h-3.5"></i>
                <span id="csv-label">Upload emails.csv</span>
                <input type="file" name="csv" accept=".csv" class="sr-only"
                       onchange="document.getElementById('csv-label').textContent = this.files[0]?.name || 'Upload emails.csv'" />
              </label>
              <button type="submit"
                      class="flex items-center gap-1.5 bg-[#002115] text-white text-xs font-semibold px-4 py-2.5 rounded-xl hover:bg-[#001a10] transition-all active:scale-95 whitespace-nowrap">
                <i data-lucide="upload" class="w-3.5 h-3.5 text-[#3ecf8e]"></i>
                Upload
              </button>
            </form>
            <p class="text-[10px] text-[#002115]/30 mt-1.5">One email per line in the CSV file.</p>
          </div>

        </div>
      </div>

    </div>

    <!-- ════ Right column (1/3) ════ -->
    <div class="xl:col-span-1 space-y-6">

      <!-- ── Top Struggle Words ── -->
      <div class="bg-white rounded-2xl border border-[#e8e4dc] shadow-card overflow-hidden">
        <div class="px-5 py-4 border-b border-[#e8e4dc] flex items-center justify-between">
          <h2 class="font-display font-semibold text-lg text-[#002115] flex items-center gap-2">
            <i data-lucide="alert-triangle" class="w-4 h-4 text-amber-500"></i>
            Top Struggle Words
          </h2>
          <span class="text-xs text-[#002115]/40">last 30 days</span>
        </div>

        <ul class="divide-y divide-[#e8e4dc]">
          <% struggleWords.forEach((w, i) => {
               const barPct = Math.round((w.clicks / maxClicks) * 100);
          %>
          <li class="px-5 py-3.5 hover:bg-[#f8f6f0] transition-colors group cursor-pointer"
              onclick="window.location='/teacher/word/<%= encodeURIComponent(w.word) %>'">
            <div class="flex items-center justify-between mb-1.5">
              <div class="flex items-center gap-2.5">
                <span class="w-5 h-5 rounded-lg bg-[#002115]/5 flex items-center justify-center text-[10px] font-mono font-bold text-[#002115]/40">#<%= i+1 %></span>
                <span class="text-sm font-semibold text-[#002115]"><%= w.word %></span>
                <span class="<%= levelBadge[w.level] %> text-[10px] font-semibold px-1.5 py-0.5 rounded-full"><%= w.level %></span>
              </div>
              <span class="text-xs font-mono text-[#002115]/50 group-hover:text-[#002115] transition-colors flex items-center gap-0.5">
                <i data-lucide="mouse-pointer-click" class="w-3 h-3"></i>
                <%= w.clicks %>
              </span>
            </div>
            <div class="w-full h-1.5 bg-[#e8e4dc] rounded-full overflow-hidden">
              <div class="h-full bg-gradient-to-r from-amber-400 to-amber-500 rounded-full transition-all duration-500"
                   style="width: <%= barPct %>%"></div>
            </div>
          </li>
          <% }) %>
        </ul>

        <div class="px-5 py-3.5 bg-[#f8f6f0] border-t border-[#e8e4dc]">
          <a href="/teacher/vocabulary" class="text-xs text-[#3ecf8e] hover:underline flex items-center gap-1">
            <i data-lucide="external-link" class="w-3 h-3"></i> Full Vocabulary Report
          </a>
        </div>
      </div>

      <!-- ── Quick Student Table ── -->
      <div class="bg-white rounded-2xl border border-[#e8e4dc] shadow-card overflow-hidden">
        <div class="px-5 py-4 border-b border-[#e8e4dc]">
          <h2 class="font-display font-semibold text-base text-[#002115] flex items-center gap-2">
            <i data-lucide="users" class="w-4 h-4 text-[#3ecf8e]"></i>
            Recent Student Activity
          </h2>
        </div>
        <ul class="divide-y divide-[#e8e4dc] text-sm">
          <%
          const sampleStudents = [
            { name: 'Maya Patel',     level: 'B1', articles: 6, status: 'active'   },
            { name: 'Jordan Lee',     level: 'A2', articles: 3, status: 'active'   },
            { name: 'Sam Okafor',     level: 'B2', articles: 9, status: 'active'   },
            { name: 'Priya Sharma',   level: 'A1', articles: 1, status: 'idle'     },
            { name: 'Chris Mensah',   level: 'B1', articles: 4, status: 'idle'     },
          ];
          %>
          <% sampleStudents.forEach(s => { %>
          <li class="px-5 py-3 flex items-center justify-between hover:bg-[#f8f6f0] transition-colors">
            <div class="flex items-center gap-2.5">
              <div class="w-7 h-7 rounded-full bg-[#002115] text-[#3ecf8e] flex items-center justify-center text-xs font-bold flex-shrink-0">
                <%= s.name.split(' ').map(n => n[0]).join('') %>
              </div>
              <div>
                <p class="text-xs font-medium text-[#002115]"><%= s.name %></p>
                <p class="text-[10px] text-[#002115]/40"><%= s.articles %> articles this week</p>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <span class="<%= levelBadge[s.level] %> text-[10px] font-semibold px-1.5 py-0.5 rounded-full"><%= s.level %></span>
              <span class="w-2 h-2 rounded-full <%= s.status === 'active' ? 'bg-[#3ecf8e]' : 'bg-[#002115]/20' %>"></span>
            </div>
          </li>
          <% }) %>
        </ul>
        <div class="px-5 py-3.5 bg-[#f8f6f0] border-t border-[#e8e4dc]">
          <a href="/teacher/students" class="text-xs text-[#3ecf8e] hover:underline flex items-center gap-1">
            <i data-lucide="external-link" class="w-3 h-3"></i> View All Students
          </a>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  lucide.createIcons();

  function copyCode() {
    const code  = document.getElementById('class-code').textContent;
    const label = document.getElementById('copy-label');
    navigator.clipboard.writeText(code).then(() => {
      label.textContent = 'Copied!';
      setTimeout(() => label.textContent = 'Copy', 2000);
    });
  }

  // Wire up Chart.js here when ready, e.g.:
  // const ctx = document.getElementById('chart-container');
  // new Chart(ctx, { type: 'bar', data: { ... } });
</script>